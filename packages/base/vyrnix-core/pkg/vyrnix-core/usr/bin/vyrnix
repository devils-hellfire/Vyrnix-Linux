#!/usr/bin/env bash

set -euo pipefail

VERSION="0.1.1"

show_help() {
  cat <<'EOF'
vyrnix - basic Vyrnix system utility

Usage:
  vyrnix <command>

Commands:
  help        Show this help
  version     Show version
  info        Show basic system information
  doctor      Run simple environment checks

This is the minimal core utility.
Advanced management may later move into dedicated tools such as:
  - vyrnix-profile
  - vyrnix-hwdetect
  - vyrnixctl
EOF
}

show_version() {
  echo "vyrnix ${VERSION}"
}

load_core_conf() {
  if [[ -r /etc/vyrnix/core.conf ]]; then
    # shellcheck disable=SC1091
    source /etc/vyrnix/core.conf
  fi
}

show_info() {
  load_core_conf

  echo "Vyrnix core information"
  echo "-----------------------"
  echo "Distribution : ${VYRNIX_NAME:-Vyrnix Linux}"
  echo "Edition      : ${VYRNIX_EDITION:-core}"
  echo "Base         : ${VYRNIX_BASE:-arch}"
  echo "Architecture : $(uname -m)"
  echo "Kernel       : $(uname -r)"
  echo "Hostname     : $(hostnamectl --static 2>/dev/null || hostname)"
}

run_doctor() {
  local failed=0
  local cmd

  echo "Running simple Vyrnix core checks..."
  echo

  for cmd in bash pacman systemctl uname; do
    if command -v "${cmd}" >/dev/null 2>&1; then
      echo "[ok] ${cmd} found"
    else
      echo "[!!] ${cmd} missing"
      failed=1
    fi
  done

  for path in /etc/vyrnix /usr/share/vyrnix /var/lib/vyrnix; do
    if [[ -e "${path}" ]]; then
      echo "[ok] ${path} present"
    else
      echo "[!!] ${path} missing"
      failed=1
    fi
  done

  if [[ -f /etc/vyrnix/core.conf ]]; then
    echo "[ok] /etc/vyrnix/core.conf present"
  else
    echo "[!!] /etc/vyrnix/core.conf missing"
    failed=1
  fi

  if [[ -f /usr/share/vyrnix/release ]]; then
    echo "[ok] /usr/share/vyrnix/release present"
  else
    echo "[!!] /usr/share/vyrnix/release missing"
    failed=1
  fi

  echo
  if [[ ${failed} -ne 0 ]]; then
    echo "One or more checks failed."
    return 1
  fi

  echo "All core checks passed."
}

main() {
  local cmd="${1:-help}"

  case "${cmd}" in
    help|-h|--help)
      show_help
      ;;
    version|-V|--version)
      show_version
      ;;
    info)
      show_info
      ;;
    doctor)
      run_doctor
      ;;
    *)
      echo "Unknown command: ${cmd}" >&2
      echo
      show_help
      exit 1
      ;;
  esac
}

main "$@"
