post_install() {
  mkdir -p /var/lib/vyrnix >/dev/null 2>&1 || true

  if [[ ! -f /var/lib/vyrnix/active-profile ]]; then
    echo "balance" > /var/lib/vyrnix/active-profile
  fi

  echo "==> Vyrnix profile manager installed."
  echo "==> Default active profile: $(cat /var/lib/vyrnix/active-profile 2>/dev/null || echo balance)"
}

post_upgrade() {
  post_install
}
